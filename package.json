{
  "name": "pavilion",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:worker": "wrangler dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "deploy": "npm run build:frontend && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply pavilion-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply pavilion-db",
    "db:migrate:new": "wrangler d1 migrations create pavilion-db"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "hono": "^4.6.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.83.0"
  }
}
