{
  "name": "pavilion",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "db:migrate:local": "wrangler d1 migrations apply pavilion-db --local",
