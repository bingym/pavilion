    "antd": "^5.21.0",
    "aws4fetch": "^1.0.20",
    "axios": "^1.7.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.41.0",
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.1.0",
    "wrangler": "^4.101.0"
  }
